{
  "cases": [
    {
      "id": "clustering-field-presence",
      "name": "Numeric feature CSV produces required keys",
      "inputPath": "tests/fixtures/minimal.csv",
      "timeoutMs": 120000,
      "expected": {
        "kind": "field-presence",
        "jsonPath": "*.json",
        "requiredKeys": ["overall", "search", "clusters"]
      }
    },
    {
      "id": "clustering-invalid-extension",
      "name": "Invalid extension must fail",
      "inputPath": "tests/fixtures/invalid.txt",
      "timeoutMs": 60000,
      "expected": {
        "kind": "must-fail",
        "expectedErrorPattern": "input extension"
      }
    },
    {
      "id": "clustering-missing-cols",
      "name": "Too few numeric features must fail",
      "inputPath": "tests/fixtures/missing-cols.csv",
      "timeoutMs": 60000,
      "expected": {
        "kind": "must-fail",
        "expectedErrorPattern": "数值特征过少"
      }
    },
    {
      "id": "clustering-too-few-rows",
      "name": "Too few samples must fail",
      "inputPath": "tests/fixtures/too-few-rows.csv",
      "timeoutMs": 60000,
      "expected": {
        "kind": "must-fail",
        "expectedErrorPattern": "样本数过少"
      }
    }
  ]
}
