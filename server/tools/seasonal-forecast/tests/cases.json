{
  "cases": [
    {
      "id": "seasonal-forecast-field-presence",
      "name": "Minimal CSV required fields",
      "inputPath": "tests/fixtures/minimal.csv",
      "timeoutMs": 60000,
      "expected": {
        "kind": "field-presence",
        "jsonPath": "*.json",
        "requiredKeys": ["decomposed", "forecast", "dataPoints", "seasonalPeriod"]
      }
    },
    {
      "id": "seasonal-forecast-invalid-extension",
      "name": "Invalid extension must fail",
      "inputPath": "tests/fixtures/invalid.txt",
      "timeoutMs": 60000,
      "expected": {
        "kind": "must-fail",
        "expectedErrorPattern": "input extension"
      }
    },
    {
      "id": "seasonal-forecast-missing-date",
      "name": "CSV missing date column must fail",
      "inputPath": "tests/fixtures/missing-date.csv",
      "timeoutMs": 60000,
      "expected": {
        "kind": "must-fail",
        "expectedErrorPattern": "缺少必需字段"
      }
    },
    {
      "id": "seasonal-forecast-too-few-rows",
      "name": "CSV with too few rows must fail",
      "inputPath": "tests/fixtures/too-few-rows.csv",
      "timeoutMs": 60000,
      "expected": {
        "kind": "must-fail",
        "expectedErrorPattern": "数据点过少"
      }
    }
  ]
}